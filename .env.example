# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# Sillage V2 API — key alone activates live mode.
# Confirmed base: https://api.getsillage.com/api/v2 (persona/agents/watchlists/companies/leads)
SILLAGE_API_KEY=
# SILLAGE_API_BASE=https://api.getsillage.com/api/v2   # override only if onboarding says otherwise
# SILLAGE_SIGNALS_PATH=   # detections LIST route (from onboarding); until set, the
#                         # pipeline reads data/sillage/detections.json (MCP export)

# FullEnrich (REST v2, auth: Authorization: Bearer <key>)
# Base URL: https://app.fullenrich.com/api/v2
FULLENRICH_API_KEY=

# Mantiks — second hiring-signal source (job changes + job-board scans),
# corroborates Sillage on the same company. Key alone does not activate full
# live mode: the REST base/path were not available this session (no API docs),
# so the client stays on fixtures until MANTIKS_API_BASE/MANTIKS_SIGNALS_PATH
# are confirmed from Mantiks' own reference. Set the key now, fill the rest
# once known.
MANTIKS_API_KEY=
# MANTIKS_API_BASE=
# MANTIKS_SIGNALS_PATH=

# Anthropic (Claude) — the orchestrator
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-8   # override the model the agent runs on

# Claude Managed Agents (the "backbone on Claude Platform" path).
# MCP endpoints for the hosted agent to call Sillage / FullEnrich itself.
# Get the URLs from the hackathon onboarding. Leave blank to run without live MCP.
# SILLAGE_MCP_URL=
# FULLENRICH_MCP_URL=
# Filled in by `npm run platform:setup` — paste its output here:
# WAKE_ENVIRONMENT_ID=
# WAKE_VAULT_ID=
# WAKE_AGENT_ID=
# ANTHROPIC_WORKSPACE_SLUG=default   # only if your session lives in a non-default workspace

# HubSpot (draft tasks only, never auto-send)
HUBSPOT_TOKEN=

# Gamma (visual asset generation, auth header X-API-KEY, base per developers.gamma.app)
GAMMA_API_KEY=

# Gradium (voice AI: TTS / STT / voice cloning) — text-to-voice-note for the
# client-expansion channel (src/actions/40-gradium-voice-note.js). No API docs
# available this session: base/path are UNCONFIRMED placeholders, live mode
# falls back to a deterministic local placeholder on any failure. Set
# GRADIUM_API_BASE once the real endpoint is known.
GRADIUM_API_KEY=
# GRADIUM_API_BASE=
GRADIUM_VOICE_ID=   # the cloned/selected voice id to speak the script (defaults to "default")

# Slack — the real dispatch path for a Gradium voice note (node src/cli.js
# send <action-id>): posts the script + audio link into a channel, a human
# forwards it to the client's WhatsApp themselves. Chosen over the direct
# WhatsApp API below because it needs no Meta Business onboarding.
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# WhatsApp (Meta Cloud API) — parked. Not wired into `send` (Slack is, see
# above); kept here for when the Meta Business setup below is real and
# direct sending is worth revisiting. See README "what's missing".
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_BASE=https://graph.facebook.com/v21.0

# Local server
PORT=3000
