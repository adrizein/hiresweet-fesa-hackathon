# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# Sillage V2 API — key alone activates live mode.
# Confirmed base: https://api.getsillage.com/api/v2 (persona/agents/watchlists/companies/leads)
SILLAGE_API_KEY=
# SILLAGE_API_BASE=https://api.getsillage.com/api/v2   # override only if onboarding says otherwise
# SILLAGE_SIGNALS_PATH=   # detections LIST route (from onboarding); until set, the
#                         # pipeline reads data/sillage/detections.json (MCP export)

# FullEnrich (REST v2, auth: Authorization: Bearer <key>)
# Base URL: https://app.fullenrich.com/api/v2
FULLENRICH_API_KEY=

# Anthropic (Claude) — the orchestrator
ANTHROPIC_API_KEY=

# HubSpot (draft tasks only, never auto-send)
HUBSPOT_TOKEN=

# Gamma (visual asset generation, auth header X-API-KEY, base per developers.gamma.app)
GAMMA_API_KEY=

# Gradium (voice AI: TTS / STT / voice cloning)
GRADIUM_API_KEY=

# Local server
PORT=3000
