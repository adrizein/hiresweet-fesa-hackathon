# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# Sillage V2 API (base URL + endpoints from the on-site onboarding)
SILLAGE_API_KEY=
# SILLAGE_API_BASE=   # fill once the onboarding gives you the base URL

# FullEnrich (REST v2, auth: Authorization: Bearer <key>)
# Base URL: https://app.fullenrich.com/api/v2
FULLENRICH_API_KEY=

# Anthropic (Claude) — the orchestrator
ANTHROPIC_API_KEY=

# HubSpot (draft tasks only, never auto-send)
HUBSPOT_TOKEN=

# Gamma (visual asset generation, auth header X-API-KEY, base per developers.gamma.app)
GAMMA_API_KEY=

# Gradium (voice AI: TTS / STT / voice cloning)
GRADIUM_API_KEY=

# Local server
PORT=3000
