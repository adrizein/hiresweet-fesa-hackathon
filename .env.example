# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# Wake runs on Claude Managed Agents. This .env is only used by the LOCAL deploy
# toolkit (deploy/*.js) run from a dev machine — production is entirely hosted.

# Anthropic — creates/updates the hosted agent and reads the review store.
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-8              # override the model the agent runs on
# ANTHROPIC_WORKSPACE_SLUG=default          # only if your workspace is not "default"

# Sillage + FullEnrich — attached to the hosted agent as remote MCP servers.
# The keys are wired into the vault as static_bearer MCP credentials by deploy.js.
SILLAGE_API_KEY=
FULLENRICH_API_KEY=
# Public MCP endpoint URLs (deploy.js defaults to these; override only if needed):
# SILLAGE_MCP_URL=https://api.getsillage.com/api/mcp/v2
# FULLENRICH_MCP_URL=https://mcp.fullenrich.com/mcp

# HubSpot — the agent reads it live with curl (read-only). The token is wired
# into the vault as an environment_variable credential, injected at egress toward
# api.hubapi.com, so the agent never sees the raw value. A HubSpot private-app token.
HUBSPOT_TOKEN=

# Schedule for the cron deployment (deploy.js defaults shown):
# WAKE_CRON=0 7 * * 1-5                      # POSIX cron; weekday mornings
# WAKE_TZ=Europe/Paris                       # IANA timezone

# Resolved resource ids are written by deploy.js to deploy/.deploy-state.json
# (gitignored) — you do not fill these in by hand.
